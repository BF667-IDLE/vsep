   },
   "outputs": [],
   "source": [
    "#@title Select Model\n",
    "#@markdown Pick from the leaderboard or enter a custom filename\n",
    "\n",
    "sorted_names = sorted(MODEL_CATALOG.keys(), key=lambda k: MODEL_CATALOG[k][\"sdr\"], reverse=True)\n",
    "dropdown_list = sorted_names + [\"(custom filename)\"]\n",
    "\n",
    "model_display_name = \"BS Roformer EP 317 SDR 12.98\" #@param [\"BS Roformer EP 317 SDR 12.98\", \"Mel Roformer Viperx SDR 12.61\", \"BS Roformer Viperx 1297\", \"Demucs v4 Fine Tuned\", \"MDX23C InstVoc HQ SDR 11.95\", \"MDX Net Inst HQ 2 SDR 10.93\", \"MDX Net Inst 1 SDR 10.65\", \"MDX Net Inst HQ 4 SDR 10.49\", \"MDX23C InstVoc\", \"Reverb HQ\", \"Echo HQ\", \"De-Esser MDX\", \"MDXC Guitar SDR 10.80\", \"MDXC Drum\", \"MDXC Bass\", \"MDXC Piano\", \"MDX Net Karaoke 2\", \"Kim Vocal 2\", \"Demucs v4 6 Stem\", \"VR 5 HP\", \"(custom filename)\"]\n",
    "\n",
    "if model_display_name == \"(custom filename)\":\n",
    "    custom_name = \"model_bs_roformer_ep_317_sdr_12.9755.ckpt\" #@param {type:\"string\"}\n",
    "    selected_model = custom_name\n",
    "    print(f\"Using custom model: {selected_model}\")\n",
    "else:\n",
    "    selected_model = MODEL_CATALOG[model_display_name][\"filename\"]\n",
    "    info = MODEL_CATALOG[model_display_name]\n",
    "    print(f\"Model:     {model_display_name}\")\n",
    "    print(f\"Filename:  {selected_model}\")\n",
    "    print(f\"Arch:      {info['arch']}\")\n",
    "    print(f\"Stems:     {info['stems']}\")\n",
    "    print(f\"SDR:       {info['sdr']}\")"
